# AI provider: openrouter | ollama | custom  (default: openrouter)
AI_PROVIDER=openrouter

# OpenRouter API settings (used when AI_PROVIDER=openrouter or custom)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-3.1-pro-preview

# Ollama settings (used when AI_PROVIDER=ollama)
# Set OLLAMA_BASE_URL to your Proxmox Ollama instance IP
OLLAMA_BASE_URL=http://192.168.1.50:11434
OLLAMA_MODEL=qwen3.5:2b

# NAS CIFS sync settings (for mounting \\192.168.1.100\NAS_Commun_Vol2\DOCUMIND\originals)
NAS_HOST=192.168.1.100
NAS_SHARE=NAS_Commun_Vol2
NAS_PATH=DOCUMIND/originals
NAS_USERNAME=Alex
NAS_PASSWORD=Alex

# Internal Documind API URL used by the NAS sync (default: http://localhost:8000)
DOCUMIND_API_URL=http://localhost:8000
